{
  "name": "fetch-smartly",
  "version": "1.0.2",
  "description": "Zero-dependency, isomorphic HTTP client with intelligent retry, circuit breaker, and offline queue for Node.js and browsers",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "fetch",
    "http",
    "http-client",
    "retry",
    "exponential-backoff",
    "circuit-breaker",
    "rate-limit",
    "timeout",
    "abort",
    "isomorphic",
    "node-fetch",
    "browser-fetch",
    "offline-queue",
    "request-deduplication",
    "zero-dependency",
    "typescript",
    "fetch-wrapper",
    "resilient-http",
    "fetch-smartly",
    "backoff-jitter"
  ],
  "author": "Ali Raza",
  "homepage": "https://Ali-Raza-Arain.github.io/fetch-smartly/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ali-Raza-Arain/fetch-smartly.git"
  },
  "bugs": {
    "url": "https://github.com/Ali-Raza-Arain/fetch-smartly/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitepress": "^1.6.0"
  }
}
